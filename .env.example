# SN21 Monitor — local development
# Copy to `.env` and adjust: `cp .env.example .env`
# Loaded automatically via python-dotenv (see config.py).

# Dashboard login (required in production; set for local testing)
DASHBOARD_PASSWORD=change-me

# Where daily_log.json and owner_ledger.json live (use a writable path locally)
SN21_DATA_DIR=./data

# First day of your ownership schedule (YYYY-MM-DD)
OWNERSHIP_START_DATE=2026-02-19

# Subtensor network for chain backfill only (historical blocks need archive)
# Daily collection uses finney in code; backfill reads this env.
SUBTENSOR_ARCHIVE_NETWORK=archive
